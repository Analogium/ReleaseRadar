# =========================================================================
# Modèle de configuration PRODUCTION.
#   Sur le serveur : copier en `.env` (jamais versionné) et remplir les valeurs.
#   `docker compose -f docker-compose.prod.yml` lit automatiquement le fichier .env.
# =========================================================================

# Domaine (doit pointer, via un enregistrement DNS A, vers l'IP publique de la VM)
DOMAIN=releaseradar.example.com

# Base de données — mot de passe FORT (générer : openssl rand -base64 24)
POSTGRES_PASSWORD=change-me-strong-random

# JWT — clé base64 d'au moins 32 octets (générer : openssl rand -base64 48)
JWT_SECRET=change-me-base64-32bytes-minimum

# SMTP Brevo (ou autre relais) pour les emails de notification
SMTP_USERNAME=change-me
SMTP_PASSWORD=change-me
MAIL_FROM=ton-adresse-verifiee@exemple.com

# Optionnel : surcharger l'hôte/port SMTP (défauts : smtp-relay.brevo.com:587)
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
